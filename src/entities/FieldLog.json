{
  "name": "FieldLog",
  "type": "object",
  "properties": {
    "rep_id": {
      "type": "string",
      "description": "User ID of the rep"
    },
    "rep_name": {
      "type": "string",
      "description": "Rep name for quick reference"
    },
    "date": {
      "type": "string",
      "format": "date",
      "description": "Date of field activity"
    },
    "neighborhood": {
      "type": "string",
      "description": "Area/neighborhood worked"
    },
    "hours_in_field": {
      "type": "number",
      "description": "Total hours spent in field"
    },
    "doors_knocked": {
      "type": "number",
      "description": "Number of doors knocked"
    },
    "conversations": {
      "type": "number",
      "description": "Number of meaningful conversations"
    },
    "appointments_set": {
      "type": "number",
      "description": "Appointments scheduled"
    },
    "closures": {
      "type": "number",
      "description": "Sales closed"
    },
    "script_used": {
      "type": "boolean",
      "description": "Did rep use the script?"
    },
    "coach_present": {
      "type": "boolean",
      "description": "Was a coach present?"
    },
    "top_objections": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Top 3 objections encountered"
    },
    "what_worked": {
      "type": "string",
      "description": "What went well"
    },
    "what_to_change": {
      "type": "string",
      "description": "What to improve next time"
    },
    "self_rating": {
      "type": "number",
      "minimum": 1,
      "maximum": 5,
      "description": "Self-assessment rating 1-5"
    },
    "coach_feedback": {
      "type": "string",
      "description": "Coach feedback text"
    },
    "coach_feedback_audio_url": {
      "type": "string",
      "description": "Audio feedback from coach"
    },
    "needs_attention": {
      "type": "boolean",
      "default": false,
      "description": "Flagged for coach review"
    }
  },
  "required": [
    "rep_id",
    "date",
    "doors_knocked"
  ]
}