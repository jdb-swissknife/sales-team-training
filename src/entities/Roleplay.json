{
  "name": "Roleplay",
  "type": "object",
  "properties": {
    "rep_id": {
      "type": "string",
      "description": "User ID of the rep"
    },
    "rep_name": {
      "type": "string",
      "description": "Rep name"
    },
    "assignment_id": {
      "type": "string",
      "description": "Reference to Assignment if assigned"
    },
    "title": {
      "type": "string",
      "description": "Roleplay scenario title"
    },
    "scenario_type": {
      "type": "string",
      "enum": [
        "Door Approach",
        "Qualifying",
        "Presentation",
        "Objection Handling",
        "Close",
        "Follow-up"
      ],
      "description": "Type of roleplay"
    },
    "script_used": {
      "type": "string",
      "description": "Which script was used"
    },
    "recording_url": {
      "type": "string",
      "description": "Video or audio recording URL"
    },
    "duration_seconds": {
      "type": "number",
      "description": "Recording duration"
    },
    "partner_name": {
      "type": "string",
      "description": "Practice partner if applicable"
    },
    "self_notes": {
      "type": "string",
      "description": "Rep's self-assessment"
    },
    "status": {
      "type": "string",
      "enum": [
        "Submitted",
        "Under Review",
        "Approved",
        "Needs Improvement"
      ],
      "default": "Submitted",
      "description": "Review status"
    },
    "coach_feedback": {
      "type": "string",
      "description": "Coach feedback text"
    },
    "coach_rating": {
      "type": "number",
      "minimum": 1,
      "maximum": 5,
      "description": "Coach rating 1-5"
    },
    "timestamp_feedback": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "timestamp": {
            "type": "string"
          },
          "comment": {
            "type": "string"
          }
        }
      },
      "description": "Timestamped feedback points"
    },
    "reviewed_by": {
      "type": "string",
      "description": "Coach who reviewed"
    },
    "reviewed_date": {
      "type": "string",
      "format": "date",
      "description": "Date reviewed"
    }
  },
  "required": [
    "rep_id",
    "title",
    "scenario_type"
  ]
}